# =============================================================================
# Dischordian Saga - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- REQUIRED ---

# MySQL database connection string
# Railway provides this automatically when you add a MySQL service
DATABASE_URL=mysql://user:password@host:3306/database

# Secret key for signing session cookies (generate a random string)
# You can generate one at: https://generate-secret.vercel.app/64
JWT_SECRET=your-random-secret-key-here

# --- AUTHENTICATION (Manus OAuth) ---
# These connect to the Manus OAuth provider for user login
VITE_APP_ID=your-app-id
OAUTH_SERVER_URL=https://your-oauth-server-url
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal-url
OWNER_OPEN_ID=your-owner-open-id

# --- AI / LLM (for Elara ship AI) ---
# Any OpenAI-compatible API (OpenAI, OpenRouter, etc.)
LLM_API_URL=https://api.openai.com
LLM_API_KEY=sk-your-api-key-here

# --- PAYMENTS (optional) ---
# Only needed if you want to accept payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- CLIENT-SIDE AI (optional, for map features) ---
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# --- MISC ---
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
