# =============================================================================
# Dischordian Saga - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- REQUIRED ---

# MySQL database connection string
# Railway provides this automatically when you add a MySQL service
DATABASE_URL=mysql://user:password@host:3306/database

# Secret key for signing session cookies (generate a random string)
# You can generate one at: https://generate-secret.vercel.app/64
JWT_SECRET=your-random-secret-key-here

# --- GOOGLE OAUTH (for user login) ---
# Create credentials at: https://console.cloud.google.com/apis/credentials
# 1. Create a new OAuth 2.0 Client ID (Web application)
# 2. Add authorized redirect URI: https://your-domain.com/api/oauth/callback
# 3. Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# This must match GOOGLE_CLIENT_ID (used by the frontend)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Your Google account's unique ID (makes you the admin)
# You can find this after first login by checking the database users table
OWNER_OPEN_ID=

# --- AI / LLM (for Elara ship AI) ---
# Any OpenAI-compatible API (OpenAI, OpenRouter, etc.)
LLM_API_URL=https://api.openai.com
LLM_API_KEY=sk-your-api-key-here

# --- PAYMENTS (optional) ---
# Only needed if you want to accept payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- CLIENT-SIDE AI (optional, for map features) ---
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# --- MISC ---
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
